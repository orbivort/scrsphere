# ===========================================
# K6 Load Testing Environment Configuration
# ===========================================
# Copy this file to .env.k6 and customize as needed.
# The .env.k6 file is loaded automatically by dotenv-cli when running loadtest scripts.
# ===========================================

# Target API URL
# Development: http://localhost:5001
# Test: http://localhost:5002
# Production: https://api.your-domain.com
BASE_URL=http://localhost:5002

# Test Data Configuration
TEST_USERS=100
TEST_TEAMS=10

# Output Configuration
OUTPUT_FORMAT=optimized
BUCKET_SIZE=10
RESULTS_DIR=k6/results
