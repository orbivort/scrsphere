# ===========================================
# Scrsphere Backend Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed.
# ===========================================

# ===========================================
# Server Configuration (Optional)
# ===========================================
# Port for the backend server
# Default: 5000
PORT=5001

# Node environment
# Options: development, production, test
NODE_ENV=development

# ===========================================
# Database Configuration (REQUIRED)
# ===========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/scrsphere_dev

# ===========================================
# JWT Configuration (REQUIRED for production)
# ===========================================
# Secret key for JWT signing (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long-for-production

# Access token expiration
# Default: 15m
JWT_EXPIRES_IN=15m

# Refresh token expiration
# Default: 7d
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# CORS Configuration (Optional)
# ===========================================
# Comma-separated list of allowed origins for CORS
# Default: http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ===========================================
# Session Configuration (Optional)
# ===========================================
# Session idle timeout in milliseconds (30 minutes)
SESSION_IDLE_TIMEOUT_MS=1800000

# Session absolute timeout in milliseconds (24 hours)
SESSION_ABSOLUTE_TIMEOUT_MS=86400000

# Warning threshold before timeout in milliseconds (2 minutes)
SESSION_WARNING_THRESHOLD_MS=120000

# Session cleanup interval in milliseconds (1 hour)
SESSION_CLEANUP_INTERVAL_MS=3600000

# Maximum concurrent sessions per user
MAX_CONCURRENT_SESSIONS=5

# ===========================================
# Rate Limiting (Optional)
# ===========================================
# Time window for rate limiting in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Notification Configuration (Optional)
# ===========================================
# Polling interval in seconds for frontend notification checks
NOTIFICATION_POLLING_INTERVAL_SECONDS=30

# Days to retain notifications before cleanup (0 = disabled)
NOTIFICATION_RETENTION_DAYS=30

# Cron schedule for notification cleanup (default: 2 AM daily)
NOTIFICATION_CLEANUP_CRON=0 2 * * *

# Maximum items per page for notifications
NOTIFICATION_MAX_PAGE_SIZE=50

# ===========================================
# Logging Configuration (Optional)
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# ===========================================
# Health Check Configuration (Optional)
# ===========================================
# Database health check timeout in milliseconds
HEALTH_CHECK_DATABASE_TIMEOUT=5000

# ===========================================
# Email Configuration (REQUIRED for production)
# ===========================================
# Email provider: smtp, sendgrid, or ses
# Default: smtp
EMAIL_PROVIDER=smtp

# Frontend URL for email links (REQUIRED in production)
# Example: https://app.example.com
FRONTEND_URL=http://localhost:5173

# Email sender name
EMAIL_FROM_NAME="Scrsphere"

# Email sender address (REQUIRED in production)
EMAIL_FROM_ADDRESS="noreply@scrsphere.local"

# Optional reply-to address
# EMAIL_REPLY_TO=support@example.com

# ===========================================
# Email Test Mode (Development Only)
# ===========================================
# Enable test mode to prevent sending real emails
# WARNING: Must be false in production
EMAIL_TEST_MODE=true

# Directory to save test emails (default: logs/emails)
EMAIL_TEST_OUTPUT_DIR=logs/emails

# Log emails to console (default: true)
EMAIL_TEST_LOG_CONSOLE=true

# Save emails to files (default: true)
EMAIL_TEST_SAVE_FILE=true

# ===========================================
# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# ===========================================
# SMTP server host
SMTP_HOST=smtp.example.com

# SMTP server port (default: 587)
SMTP_PORT=587

# Use TLS/SSL (default: false for port 587, true for port 465)
SMTP_SECURE=false

# SMTP authentication
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Connection pooling (default: true)
SMTP_POOL=true

# Maximum concurrent connections (default: 5)
SMTP_MAX_CONNECTIONS=5

# SMTP Rate Limiting
SMTP_RATE_LIMIT_ENABLED=false
SMTP_RATE_LIMIT_MAX_MESSAGES=100
SMTP_RATE_LIMIT_WINDOW_MS=60000

# ===========================================
# SendGrid Configuration (when EMAIL_PROVIDER=sendgrid)
# ===========================================
# SendGrid API key (starts with "SG.")
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ===========================================
# AWS SES Configuration (when EMAIL_PROVIDER=ses)
# ===========================================
# AWS region for SES
# SES_REGION=us-east-1

# AWS credentials for SES
# SES_ACCESS_KEY_ID=your-aws-access-key-id
# SES_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ===========================================
# Email Feature Flags (Optional)
# ===========================================
# Enable email tracking (default: true)
# EMAIL_TRACKING=true

# Enable open tracking (default: false)
# EMAIL_OPEN_TRACKING=false

# Enable click tracking (default: false)
# EMAIL_CLICK_TRACKING=false

# Enable email queue (default: true)
# EMAIL_QUEUE=true

# ===========================================
# Email Retry Configuration (Optional)
# ===========================================
# Maximum retry attempts (default: 3, range: 1-10)
# EMAIL_RETRY_MAX_ATTEMPTS=3

# Initial backoff in milliseconds (default: 1000)
# EMAIL_RETRY_BACKOFF_MS=1000

# Maximum backoff in milliseconds (default: 30000)
# EMAIL_RETRY_MAX_BACKOFF_MS=30000

# ===========================================
# Email Retention Configuration (GDPR Compliance)
# ===========================================
# Days to retain successful email logs (default: 30)
# EMAIL_RETENTION_SUCCESSFUL_DAYS=30

# Days to retain failed email logs (default: 90)
# EMAIL_RETENTION_FAILED_DAYS=90

# Days to retain bounced email logs (default: 365)
# EMAIL_RETENTION_BOUNCED_DAYS=365

# ===========================================
# Email Circuit Breaker Configuration (Optional)
# ===========================================
# Number of failures before opening circuit (default: 5)
# EMAIL_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Time in ms before attempting to close circuit (default: 60000)
# EMAIL_CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000
