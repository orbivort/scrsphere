# ===========================================
# Scrsphere Backend Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed.
# 
# Variable Format:
#   VARIABLE_NAME=value  # [Type] Required/Optional - Description
#
# Types: string, integer, boolean, url, csv (comma-separated values)
# Required: Must be set for the application to function
# Optional: Has a sensible default value
# ===========================================

# ===========================================
# TABLE OF CONTENTS
# ===========================================
# 1. Server Configuration
# 2. Database Configuration
# 3. JWT Configuration
# 4. Session Management
# 5. Security Configuration
# 6. Rate Limiting
# 7. CORS Configuration
# 8. Logging Configuration
# 9. Notification Configuration
# 10. Event Loop Monitoring
# 11. Health Check Configuration
# 12. Account Deletion Configuration
# 13. Database Transaction Configuration
# 14. Backlog Configuration
# 15. Email Configuration
# ===========================================

# ===========================================
# 1. Server Configuration
# ===========================================
# Port for the backend server
# Type: integer | Default: 5000 | Optional
PORT=5001

# Node environment
# Type: string | Default: development | Optional
# Options: development, production, test
# IMPORTANT: Set to 'production' for production deployments
NODE_ENV=development

# API prefix for all routes
# Type: string | Default: /api | Optional
# API_PREFIX=/api

# ===========================================
# 2. Database Configuration
# ===========================================
# PostgreSQL connection string
# Type: url | Required
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/scrsphere_dev
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/scrsphere_dev

# ===========================================
# 3. JWT Configuration
# ===========================================
# Secret key for JWT signing
# Type: string | Required (auto-generated if not set)
# IMPORTANT: Generate with: openssl rand -hex 64
# Production: Must be at least 64 characters
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long-for-production

# Access token expiration time
# Type: string | Default: 15m | Optional
# Format: number + unit (s=seconds, m=minutes, h=hours, d=days)
JWT_EXPIRES_IN=15m

# Refresh token expiration time
# Type: string | Default: 7d | Optional
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# 4. Session Management
# ===========================================
# Session idle timeout in milliseconds
# Type: integer | Default: 1800000 (30 minutes) | Optional
# User is logged out after this period of inactivity
SESSION_IDLE_TIMEOUT_MS=1800000

# Session absolute timeout in milliseconds
# Type: integer | Default: 86400000 (24 hours) | Optional
# Maximum session duration regardless of activity
SESSION_ABSOLUTE_TIMEOUT_MS=86400000

# Warning threshold before session timeout in milliseconds
# Type: integer | Default: 120000 (2 minutes) | Optional
# Shows warning dialog before session expires
SESSION_WARNING_THRESHOLD_MS=120000

# Session cleanup interval in milliseconds
# Type: integer | Default: 3600000 (1 hour) | Optional
# How often expired sessions are cleaned up
SESSION_CLEANUP_INTERVAL_MS=3600000

# Maximum concurrent sessions per user
# Type: integer | Default: 5 | Optional
# Older sessions are invalidated when limit is exceeded
MAX_CONCURRENT_SESSIONS=5

# ===========================================
# 5. Security Configuration
# ===========================================
# Bcrypt salt rounds for password hashing
# Type: integer | Default: 12 | Optional
# Higher values = more secure but slower
# Range: 10-14 recommended
# BCRYPT_SALT_ROUNDS=12

# Token hash algorithm for refresh tokens
# Type: string | Default: sha256 | Optional
# Options: sha256, sha512
# TOKEN_HASH_ALGORITHM=sha256

# ===========================================
# 6. Rate Limiting
# ===========================================
# General rate limiting window in milliseconds
# Type: integer | Default: 900000 (15 minutes) | Optional
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
# Type: integer | Default: 100 | Optional
# Recommended: 200-300 for applications with data-heavy pages
RATE_LIMIT_MAX_REQUESTS=300

# Authentication endpoint rate limit (register, etc.)
# Type: integer | Default: 5 (production) | Optional
# AUTH_RATE_LIMIT_MAX=5

# Token refresh endpoint rate limit
# Type: integer | Default: 50 (production) | Optional
# Higher limit because token refresh is automatic and can be triggered by multiple tabs
# or rapid page refreshes. This is a legitimate operation that shouldn't be rate-limited strictly.
# TOKEN_REFRESH_RATE_LIMIT_MAX=50

# Login endpoint rate limit (per IP + email)
# Type: integer | Default: 10 (production) | Optional
# LOGIN_RATE_LIMIT_MAX=10

# Forgot password rate limit
# Type: integer | Default: 3 (production) | Optional
# FORGOT_PASSWORD_RATE_LIMIT_MAX=3

# Reset password rate limit
# Type: integer | Default: 5 (production) | Optional
# RESET_PASSWORD_RATE_LIMIT_MAX=5

# ===========================================
# 7. CORS Configuration
# ===========================================
# Comma-separated list of allowed origins for CORS
# Type: csv | Default: http://localhost:5173 | Optional
# Production: Must NOT include localhost
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ===========================================
# 8. Logging Configuration
# ===========================================
# Log level
# Type: string | Default: debug (dev), info (prod) | Optional
# Options: debug, info, warn, error
LOG_LEVEL=debug

# Log directory
# Type: string | Default: logs | Optional
# LOG_DIR=logs

# Maximum log file age
# Type: string | Default: 14d | Optional
# LOG_MAX_FILES=14d

# Maximum log file size
# Type: string | Default: 20m | Optional
# LOG_MAX_SIZE=20m

# Log format
# Type: string | Default: json | Optional
# Options: json, simple
# LOG_FORMAT=json

# ===========================================
# 9. Notification Configuration
# ===========================================
# Polling interval for frontend notification checks in seconds
# Type: integer | Default: 5 | Optional
# Range: 1-60
NOTIFICATION_POLLING_INTERVAL_SECONDS=30

# Days to retain notifications before cleanup
# Type: integer | Default: 30 | Optional
# Set to 0 to disable automatic cleanup (not recommended)
NOTIFICATION_RETENTION_DAYS=30

# Cron schedule for notification cleanup
# Type: string (cron) | Default: 0 2 * * * (2 AM daily) | Optional
NOTIFICATION_CLEANUP_CRON=0 2 * * *

# Maximum items per page for notifications
# Type: integer | Default: 50 | Optional
# Range: 10-100
NOTIFICATION_MAX_PAGE_SIZE=50

# ===========================================
# 10. Event Loop Monitoring
# ===========================================
# Enable event loop monitoring
# Type: boolean | Default: true (production) | Optional
# Helps detect performance issues
# EVENT_LOOP_MONITORING_ENABLED=true

# Monitoring resolution in milliseconds
# Type: integer | Default: 10 | Optional
# EVENT_LOOP_RESOLUTION=10

# Warning threshold in milliseconds
# Type: integer | Default: 100 | Optional
# EVENT_LOOP_WARN_THRESHOLD=100

# Critical threshold in milliseconds
# Type: integer | Default: 500 | Optional
# EVENT_LOOP_CRITICAL_THRESHOLD=500

# ===========================================
# 11. Health Check Configuration
# ===========================================
# Database health check timeout in milliseconds
# Type: integer | Default: 5000 | Optional
HEALTH_CHECK_DATABASE_TIMEOUT=5000

# ===========================================
# 12. Account Deletion Configuration
# ===========================================
# Grace period in days before account is permanently deleted
# Type: integer | Default: 14 | Optional
# ACCOUNT_DELETION_GRACE_PERIOD_DAYS=14

# ===========================================
# 13. Database Transaction Configuration
# ===========================================
# Start Sprint transaction settings
# Type: integer | Optional
# DB_TRANSACTION_START_SPRINT_MAX_WAIT=5000
# DB_TRANSACTION_START_SPRINT_TIMEOUT=15000
# DB_TRANSACTION_START_SPRINT_RETRIES=2

# Default transaction settings
# Type: integer | Optional
# DB_TRANSACTION_MAX_WAIT=5000
# DB_TRANSACTION_TIMEOUT=10000
# DB_TRANSACTION_RETRIES=2

# Circuit breaker settings
# Type: integer | Optional
# DB_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# DB_CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# ===========================================
# 14. Backlog Configuration
# ===========================================
# Maximum number of backlog items allowed per product goal
# Set to 0 to disable the limit
# Default: 200
BACKLOG_MAX_ITEMS_PER_GOAL=200

# ===========================================
# 15. Email Configuration
# ===========================================
# Email provider
# Type: string | Default: smtp | Required for production
# Options: smtp, sendgrid, ses
EMAIL_PROVIDER=smtp

# Frontend URL for email links
# Type: url | Default: http://localhost:5173 | Required for production
# Used for password reset, email verification links
FRONTEND_URL=http://localhost:5173

# Email sender name
# Type: string | Default: Scrsphere | Optional
EMAIL_FROM_NAME="ScrSphere"

# Email sender address
# Type: string (email) | Default: noreply@scrsphere.local | Required for production
EMAIL_FROM_ADDRESS="noreply@scrsphere.local"

# Reply-to address (optional)
# Type: string (email) | Optional
# EMAIL_REPLY_TO=support@example.com

# -------------------------------------------
# Email Test Mode (Development Only)
# -------------------------------------------
# Enable test mode to prevent sending real emails
# Type: boolean | Default: false | Optional
# WARNING: Must be false in production!
EMAIL_TEST_MODE=true

# Directory to save test emails
# Type: string | Default: logs/emails | Optional
EMAIL_TEST_OUTPUT_DIR=logs/emails

# Log emails to console
# Type: boolean | Default: true | Optional
EMAIL_TEST_LOG_CONSOLE=true

# Save emails to files
# Type: boolean | Default: true | Optional
EMAIL_TEST_SAVE_FILE=true

# -------------------------------------------
# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# -------------------------------------------
# SMTP server host
# Type: string | Required if EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com

# SMTP server port
# Type: integer | Default: 587 | Optional
# Common ports: 587 (TLS), 465 (SSL), 25 (unencrypted)
SMTP_PORT=587

# Use TLS/SSL
# Type: boolean | Default: false | Optional
# Set to true for port 465
SMTP_SECURE=false

# SMTP authentication username
# Type: string | Required if EMAIL_PROVIDER=smtp
SMTP_USER=your-smtp-username

# SMTP authentication password
# Type: string | Required if EMAIL_PROVIDER=smtp
SMTP_PASS=your-smtp-password

# Enable connection pooling
# Type: boolean | Default: true | Optional
SMTP_POOL=true

# Maximum concurrent connections
# Type: integer | Default: 5 | Optional
SMTP_MAX_CONNECTIONS=5

# SMTP Rate Limiting
# Type: boolean | Default: false | Optional
SMTP_RATE_LIMIT_ENABLED=false
# Type: integer | Default: 100 | Optional
SMTP_RATE_LIMIT_MAX_MESSAGES=100
# Type: integer | Default: 60000 | Optional
SMTP_RATE_LIMIT_WINDOW_MS=60000

# -------------------------------------------
# SendGrid Configuration (when EMAIL_PROVIDER=sendgrid)
# -------------------------------------------
# SendGrid API key
# Type: string | Required if EMAIL_PROVIDER=sendgrid
# Must start with "SG."
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# -------------------------------------------
# AWS SES Configuration (when EMAIL_PROVIDER=ses)
# -------------------------------------------
# AWS region for SES
# Type: string | Default: us-east-1 | Optional
# SES_REGION=us-east-1

# AWS access key ID
# Type: string | Required if EMAIL_PROVIDER=ses
# SES_ACCESS_KEY_ID=your-aws-access-key-id

# AWS secret access key
# Type: string | Required if EMAIL_PROVIDER=ses
# SES_SECRET_ACCESS_KEY=your-aws-secret-access-key

# -------------------------------------------
# Email Feature Flags
# -------------------------------------------
# Enable email tracking
# Type: boolean | Default: true | Optional
# EMAIL_TRACKING=true

# Enable open tracking
# Type: boolean | Default: false | Optional
# EMAIL_OPEN_TRACKING=false

# Enable click tracking
# Type: boolean | Default: false | Optional
# EMAIL_CLICK_TRACKING=false

# Enable email queue for async sending
# Type: boolean | Default: true | Optional
# EMAIL_QUEUE=true

# -------------------------------------------
# Email Retry Configuration
# -------------------------------------------
# Maximum retry attempts
# Type: integer | Default: 3 | Optional
# Range: 1-10
# EMAIL_RETRY_MAX_ATTEMPTS=3

# Initial backoff in milliseconds
# Type: integer | Default: 1000 | Optional
# EMAIL_RETRY_BACKOFF_MS=1000

# Maximum backoff in milliseconds
# Type: integer | Default: 30000 | Optional
# EMAIL_RETRY_MAX_BACKOFF_MS=30000

# -------------------------------------------
# Email Retention Configuration (GDPR Compliance)
# -------------------------------------------
# Days to retain successful email logs
# Type: integer | Default: 30 | Optional
# EMAIL_RETENTION_SUCCESSFUL_DAYS=30

# Days to retain failed email logs
# Type: integer | Default: 90 | Optional
# EMAIL_RETENTION_FAILED_DAYS=90

# Days to retain bounced email logs
# Type: integer | Default: 365 | Optional
# EMAIL_RETENTION_BOUNCED_DAYS=365

# -------------------------------------------
# Email Circuit Breaker Configuration
# -------------------------------------------
# Number of failures before opening circuit
# Type: integer | Default: 5 | Optional
# EMAIL_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Time in ms before attempting to close circuit
# Type: integer | Default: 60000 | Optional
# EMAIL_CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# ===========================================
# QUICK START
# ===========================================
# For local development:
# 1. Copy this file to .env
# 2. Update DATABASE_URL with your PostgreSQL credentials
# 3. Set JWT_SECRET to a random string (or let it auto-generate)
# 4. Keep EMAIL_TEST_MODE=true to avoid sending real emails
#
# For production:
# 1. Set NODE_ENV=production
# 2. Use strong DATABASE_URL password
# 3. Generate JWT_SECRET with: openssl rand -hex 64
# 4. Set CORS_ORIGIN to your production domains
# 5. Configure email provider (SMTP, SendGrid, or SES)
# 6. Set EMAIL_TEST_MODE=false
# ===========================================
