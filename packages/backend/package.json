{
  "name": "@scrsphere/backend",
  "version": "1.2.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Backend API for Scrsphere - Agile Scrum Lifecycle Management System",
  "keywords": [
    "agile",
    "scrum",
    "project-management",
    "nodejs",
    "express",
    "typescript",
    "prisma"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/orbivort/scrsphere.git",
    "directory": "packages/backend"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:test": "cross-env NODE_ENV=test tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "cross-env NODE_ENV=test vitest run src/__tests__/unit",
    "test:watch": "vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "test:unit": "cross-env NODE_ENV=test vitest run src/__tests__/unit",
    "test:integration": "cross-env NODE_ENV=test vitest run src/__tests__/integration",
    "test:e2e": "cross-env NODE_ENV=test vitest run src/__tests__/e2e",
    "test:all": "cross-env NODE_ENV=test vitest run",
    "test:ci": "cross-env NODE_ENV=test vitest run --coverage --reporter=json --reporter=html",
    "test:changed": "vitest run --changed",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:test": "cross-env NODE_ENV=test prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:validate": "prisma validate",
    "loadtest:data": "tsx scripts/generate-load-test-data.ts",
    "loadtest:data:clear": "tsx scripts/generate-load-test-data.ts --clear"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@scrsphere/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "sanitize-html": "^2.17.3",
    "uuid": "^14.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@faker-js/faker": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "^7.0.3",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "catalog:",
    "prettier": "catalog:",
    "prisma": "^7.7.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^24.14.1"
  }
}
