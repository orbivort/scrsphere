# ===========================================
# Scrsphere Frontend Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed.
# Vite only exposes variables prefixed with VITE_ to the client.
# ===========================================

# ===========================================
# Dev Server Configuration (Optional)
# ===========================================
# Port for Vite dev server
# Default: 5173
VITE_DEV_PORT=5173

# ===========================================
# API Configuration (REQUIRED)
# ===========================================
# Backend API URL
# For development: http://localhost:5001/api/v1
# For production: https://api.your-domain.com/api/v1
VITE_API_URL=http://localhost:5001/api/v1

# API request timeout in milliseconds
# Default: 30000 (30 seconds)
# Increase this if you have slow network connections or large payloads
# VITE_API_TIMEOUT=30000

# ===========================================
# Mock API Configuration
# ===========================================
# Controls whether the frontend uses mock API or real backend API
# Set to 'false' to use real backend API (RECOMMENDED for development)
# Set to 'true' or leave unset to use mock API (frontend-only development)
# IMPORTANT: If unset or any value other than 'false', mock API is used
VITE_USE_MOCK_API=false

# ===========================================
# Backlog Configuration
# ===========================================

# Maximum number of backlog items to fetch per request (pagination)
# This controls the initial data load size for better performance
# Default: 100
VITE_BACKLOG_ITEM_LIMIT=100

# Maximum number of backlog items allowed per product goal (capacity limit)
# This is a business rule to maintain manageable backlogs
# Set to 0 to disable the limit (unlimited)
# Default: 200
VITE_BACKLOG_MAX_ITEMS_PER_GOAL=200

# ===========================================
# Avatar Service Configuration (Optional)
# ===========================================
# URL for the avatar generation service
# Default: https://api.dicebear.com/7.x/avataaars/svg
# Used for generating user avatars when no custom avatar is set
# VITE_AVATAR_SERVICE_URL=https://api.dicebear.com/7.x/avataaars/svg

# ===========================================
# Logging Configuration (Optional)
# ===========================================
# Log level: debug, info, warn, error
# Default: debug in development, info in production
# VITE_LOG_LEVEL=info

# ===========================================
# Error Reporting Configuration (Optional)
# ===========================================
# Sentry DSN for error reporting
# Enables remote error tracking in production
# Sign up at https://sentry.io to get your DSN
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Application version for error tracking
# Automatically populated from package.json in build
# VITE_APP_VERSION=1.0.0
