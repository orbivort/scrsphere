{
  "name": "@scrsphere/frontend",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Frontend UI for Scrsphere - Agile Scrum Lifecycle Management System",
  "keywords": [
    "agile",
    "scrum",
    "project-management",
    "react",
    "typescript",
    "vite"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/scrsphere/scrsphere.git",
    "directory": "packages/frontend"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test",
    "build": "tsc -b && vite build",
    "build:analyze": "tsc -b && vite build --mode analyze",
    "preview": "vite preview",
    "serve": "vite preview --host",
    "clean": "rimraf dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "test:verbose": "cross-env NODE_ENV=test vitest run --verbose",
    "test:ci": "cross-env NODE_ENV=test vitest run --coverage --reporter=json --reporter=html",
    "test:changed": "cross-env NODE_ENV=test vitest run --changed",
    "test:ui": "cross-env NODE_ENV=test vitest --ui",
    "test:e2e": "cross-env E2E_BROWSERS=desktop playwright test",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:desktop": "cross-env E2E_BROWSERS=desktop playwright test",
    "test:e2e:mobile": "cross-env E2E_BROWSERS=mobile playwright test",
    "test:e2e:chromium": "cross-env E2E_BROWSERS=chromium playwright test",
    "test:e2e:firefox": "cross-env E2E_BROWSERS=firefox playwright test",
    "test:e2e:webkit": "cross-env E2E_BROWSERS=webkit playwright test",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen",
    "test:e2e:ci": "cross-env E2E_BROWSERS=desktop playwright test",
    "generate:icon-types": "tsx ../../scripts/utility/generate-icon-types.ts",
    "generate:icon-types:watch": "tsx ../../scripts/utility/generate-icon-types.ts --watch"
  },
  "dependencies": {
    "@scrsphere/shared": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "3.13.24",
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "cross-env": "^7.0.3",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react": "^7.37.5",
    "globals": "catalog:",
    "jsdom": "^29.0.2",
    "prettier": "catalog:",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.0",
    "vi-axe": "^1.0.0",
    "vite": "^8.0.8",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^24.14.1"
  }
}
