# ===========================================
# Scrsphere Frontend Production Environment
# ===========================================
# This file documents required and optional environment variables
# for production deployments.
#
# IMPORTANT: Do NOT commit actual production values to git!
# Use your deployment platform's environment variable injection
# (e.g., GitHub Actions secrets, Docker env vars, Kubernetes ConfigMaps)
# ===========================================

# ===========================================
# REQUIRED - API Configuration
# ===========================================
# Backend API URL (MUST be set for production)
# Use your production API endpoint
# Example: https://api.example.com/api/v1
VITE_API_URL=https://api.your-domain.com/api/v1

# ===========================================
# REQUIRED - Mock API Configuration
# ===========================================
# MUST be set to 'false' in production to use real backend API
# If unset or any other value, the app will use mock API
VITE_USE_MOCK_API=false

# ===========================================
# OPTIONAL - API Timeout
# ===========================================
# API request timeout in milliseconds
# Default: 30000 (30 seconds)
# Consider increasing for slow networks or large payloads
# VITE_API_TIMEOUT=30000

# ===========================================
# OPTIONAL - Backlog Configuration
# ===========================================
# Maximum number of backlog items to fetch per request (pagination)
# This controls the initial data load size for better performance
# Default: 100
VITE_BACKLOG_ITEM_LIMIT=100

# Maximum number of backlog items allowed per product goal (capacity limit)
# This is a business rule to maintain manageable backlogs
# Set to 0 to disable the limit (unlimited)
# Default: 200
VITE_BACKLOG_MAX_ITEMS_PER_GOAL=200

# ===========================================
# OPTIONAL - Avatar Service
# ===========================================
# URL for the avatar generation service
# Default: https://api.dicebear.com/7.x/avataaars/svg
# Consider using a self-hosted avatar service for privacy
# VITE_AVATAR_SERVICE_URL=https://api.dicebear.com/7.x/avataaars/svg

# ===========================================
# RECOMMENDED - Logging Configuration
# ===========================================
# Log level for production
# Recommended: 'info' or 'warn' (avoid 'debug' in production)
VITE_LOG_LEVEL=info

# ===========================================
# RECOMMENDED - Error Reporting
# ===========================================
# Sentry DSN for production error tracking
# Highly recommended for production deployments
# Sign up at https://sentry.io to get your DSN
# VITE_SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx

# Application version (optional, auto-populated from package.json)
# VITE_APP_VERSION=1.0.0

# ===========================================
# DEPLOYMENT NOTES
# ===========================================
# 1. Ensure CORS is properly configured on the backend
#    The backend CORS_ORIGIN must include your frontend domain
#
# 2. Ensure HTTPS is enabled for both frontend and backend
#    HTTP is not recommended for production
#
# 3. Consider using a CDN for static assets
#    Vite builds optimized production bundles
#
# 4. Set up proper error monitoring (Sentry recommended)
#    This helps identify and debug production issues
#
# 5. Configure proper caching headers
#    Static assets should have long cache times
#    HTML should have no or short cache times
# ===========================================
