{
  "name": "@scrsphere/shared",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Shared types and utilities for Scrsphere - Agile Scrum Lifecycle Management System",
  "keywords": [
    "agile",
    "scrum",
    "project-management",
    "typescript",
    "shared"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/orbivort/scrsphere.git",
    "directory": "packages/shared"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants/index.js",
      "types": "./dist/constants/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "^24.12.2",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "rimraf": "^6.1.3",
    "typescript": "catalog:"
  }
}
